      id: "line_total_check"
      message: "line_total must equal (quantity × unit_price) - discount + tax"
      expression: "this.line_total.amount == (int(this.quantity) * this.unit_price.amount) - (this.discount_amount.amount ?? 0) + (this.tax_amount.amount ?? 0)"
    }
  ];
  
  // === NOUVEAUX CHAMPS ===
  optional string notes = 9;
  optional TaxInfo tax_info = 10;
}
