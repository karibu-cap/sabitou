```protobuf
message OrderLineItem {
  string product_id = 1 [(buf.validate.field).required = true];
  Internationalized product_name = 2;
  
  // === QUANTITÉ ET UNITÉ ===
  double quantity = 3 [(buf.validate.field).double.gt = 0];
