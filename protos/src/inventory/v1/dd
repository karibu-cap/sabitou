### 3. MODIFICATION DE `inventory.proto`

**A. Mettre à jour InventoryLevel**
```protobuf
message InventoryLevel {
  string store_product_id = 1 [(buf.validate.field).required = true];
  string store_id = 2 [(buf.validate.field).required = true];
  
  // === QUANTITÉS (avec validation) ===
  
  // Disponible à la vente (somme des batches actifs)
  int32 quantity_available = 3 [(buf.validate.field).int32.gte = 0];
  
  // Réservé pour commandes non expédiées
  int32 quantity_reserved = 4 [(buf.validate.field).int32.gte = 0];
  
  // En cours de livraison vers cet entrepôt
  int32 quantity_in_transit = 5 [(buf.validate.field).int32.gte = 0];
  
  // === NOUVEAUX CHAMPS ===
  
  // Endommagé mais physiquement présent
  int32 quantity_damaged = 6 [(buf.validate.field).int32.gte = 0];
  
  // En attente (contrôle qualité, litige)
  int32 quantity_on_hold = 7 [(buf.validate.field).int32.gte = 0];
  
  // Quantité totale physique
  int32 quantity_total = 8 [
    (buf.validate.field).int32.gte = 0,
    (buf.validate.field).cel = {
      id: "total_quantity_check"
      message: "total must equal sum of all states"
      expression: "this.quantity_total == this.quantity_available + this.quantity_reserved + this.quantity_in_transit + this.quantity_damaged + this.quantity_on_hold"
    }
  ];
  
  // === SEUILS DE RÉAPPROVISIONNEMENT ===
  
  int32 min_threshold = 9;              // Seuil minimum (alerte)
  int32 reorder_point = 10;             // Point de commande
  int32 reorder_quantity = 11;          // Quantité à commander
  int32 max_threshold = 12;             // Stock maximum souhaité
  
  // === MÉTRIQUES CALCULÉES ===
  
  // Nombre de jours avant rupture (basé sur ventes moyennes)
  optional int32 days_of_supply = 13;
  
  // Date estimée de rupture de stock
  optional google.protobuf.Timestamp projected_stockout_date = 14;
  
  // Valeur totale du stock (quantity × cost)
  optional Money total_stock_value = 15;
  
  // === AUDIT ET COHÉRENCE ===
  
  google.protobuf.Timestamp last_updated = 16;
  string last_updated_by_user_id = 17;
  
  // Hash pour vérifier cohérence avec batches
  string batches_checksum = 18;
  google.protobuf.Timestamp batches_last_modified = 19;
  
  // === BATCHES ===
  repeated Batch batches = 20;
}
```

**B. Mettre à jour Batch**
```protobuf
message Batch {
  string document_id = 1 [(buf.validate.field).required = true];
  string product_id = 2 [(buf.validate.field).required = true];
  string warehouse_id = 3 [(buf.validate.field).required = true];
  
  // === QUANTITÉ ET UNITÉ ===
  int32 quantity = 4 [(buf.validate.field).int32.gte = 0];
  UnitOfMeasure unit = 5 [(buf.validate.field).required = true];
  
  // Conversion vers unité de base si différente
  optional double conversion_to_base = 6;
  
  // === DATES ===
  google.protobuf.Timestamp received_at = 7;
  optional google.protobuf.Timestamp production_date = 8;
  optional google.protobuf.Timestamp expiration_date = 9;
  
  // === FOURNISSEUR (CORRIGÉ) ===
  string supplier_id = 10 [(buf.validate.field).required = true];
  optional string supplier_batch_number = 11;      // Leur référence
  optional string supplier_invoice_number = 12;    // Numéro de facture
  
  // === COÛTS (AJOUTÉ - CRITIQUE) ===
  Money unit_cost = 13 [(buf.validate.field).required = true];
  Money total_cost = 14 [
    (buf.validate.field).required = true,
    (buf.validate.field).cel = {
      id: "total_cost_check"
      message: "total_cost must equal quantity × unit_cost"
      expression: "this.total_cost.amount == this.quantity * this.unit_cost.amount"
    }
  ];
  
  // Coût incluant transport, douane, etc.
  optional Money landed_cost = 15;
  
  // === STATUT ET QUALITÉ ===
  BatchStatus status = 16;
  optional QualityCheck quality_check = 17;
  optional string notes = 18;
  
  // === LOCALISATION (pour multi-zones dans entrepôt) ===
  optional string location_zone = 19;    // "Zone A"
  optional string location_aisle = 20;   // "Allée 3"
  optional string location_shelf = 21;   // "Étagère B2"
}

message QualityCheck {
  string inspector_user_id = 1 [(buf.validate.field).required = true];
  google.protobuf.Timestamp checked_at = 2;
  QualityResult result = 3;
  optional string notes = 4;
  repeated string defect_photo_ids = 5;
  repeated DefectDetail defects = 6;
}

enum QualityResult {
  QUALITY_RESULT_UNSPECIFIED = 0;
  QUALITY_RESULT_PASSED = 1;
  QUALITY_RESULT_PASSED_WITH_REMARKS = 2;
  QUALITY_RESULT_FAILED = 3;
  QUALITY_RESULT_PARTIAL = 4;  // Partie acceptée, partie rejetée
}

message DefectDetail {
  DefectType type = 1;
  int32 affected_quantity = 2;
  string description = 3;
}

enum DefectType {
  DEFECT_TYPE_UNSPECIFIED = 0;
  DEFECT_TYPE_PACKAGING_DAMAGE = 1;
  DEFECT_TYPE_PRODUCT_DAMAGE = 2;
  DEFECT_TYPE_CONTAMINATION = 3;
  DEFECT_TYPE_WRONG_ITEM = 4;
  DEFECT_TYPE_EXPIRED = 5;
  DEFECT_TYPE_QUALITY_ISSUE = 6;
}
